#![no_std] // No standard library = smaller attack surface & better for Space

use wolfssl_sys as wolf; // FIPS-validated C bindings

pub struct LunarCrypt {
    context: *mut wolf::WOLFSSL_CTX,
}

impl LunarCrypt {
    /// Initialize hardware-accelerated AES-GCM for the Zynq MPSoC
    pub fn new() -> Result<Self, CryptoError> {
        unsafe {
            // 1. Initialize wolfSSL library
            if wolf::wolfSSL_Init() != wolf::WOLFSSL_SUCCESS {
                return Err(CryptoError::InitFailed);
            }
            
            // 2. Load FIPS keys from Zynq hardware eFUSEs/Secure Storage
            // This is where we call the Zynq-specific CSU drivers
            Self::load_hardware_keys()?;

            Ok(Self { context: wolf::wolfSSL_CTX_new(wolf::wolfTLSv1_3_client_method()) })
        }
    }
}
